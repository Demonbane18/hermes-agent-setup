# =============================================================================
# Never commit secrets or runtime state — only templates.
# =============================================================================

# --- Per-gateway secrets & state ---------------------------------------------
gateways/*/.env
gateways/*/sessions/
gateways/*/memories/
gateways/*/logs/
gateways/*/gateway.pid
gateways/*/gateway_state.json
gateways/*/auth.json
gateways/*/*_token.json
gateways/*/*_secret.json
gateways/*/models_dev_cache.json
gateways/*/ollama_cloud_models_cache.json
gateways/*/dogfood-output/
gateways/*/bin/
gateways/*/cron/

# --- Skills are NOT gitignored ------------------------------------------------
# skills/ holds the agent's procedural knowledge. Commit it; that's the whole
# point of "compounding skills." Per-gateway in split-brain mode, symlinked
# in full-share mode — git resolves both fine.

# --- Shared handoff + canonical shared store --------------------------------
# Keep README files and ignored handoff notes; ignore live shared memories
# and any per-host shared sessions/.
gateways/_shared/handoff/*.md
!gateways/_shared/handoff/README.md
gateways/_shared/memories/
gateways/_shared/sessions/

# --- Backup files left by bootstrap.sh when replacing run.sh / inject_config.py
*.bak

# --- Python bytecode caches from local lint/py_compile runs
__pycache__/
*.pyc

# --- Local-only prompt-context drop (images / screenshots / scratch files)
# Folder is committed via README so it exists on fresh clones; everything
# inside it stays local.
prompt-context/*
!prompt-context/README.md

# --- Diagram tooling ----------------------------------------------------------
diagrams/node_modules/
diagrams/package-lock.json

# --- Personal drafts (social posts, scratch notes) — never push -------------
social/
demo-script-fb.md

# --- OS / editor / agent noise -----------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/
.claude/
