#!/usr/bin/env bash
# =============================================================================
# Hermes Multi-Gateway Launcher
# =============================================================================
# Universal, gateway-agnostic launcher. Auto-discovers every sibling directory
# that has both `.env` and `config.yaml` and treats it as a gateway. Any
# directory whose name starts with `_` (e.g. `_shared/`) is silently skipped.
#
# Lives at <parent>/run.sh on the VPS. Same script works for `~/gateways/`,
# `~/agents/`, `~/hermes-bots/`, or whatever parent path you pick.
#
# Usage:
#   ./run.sh                  Start every discovered gateway (alias: all, both)
#   ./run.sh all | both       Same as default
#   ./run.sh list             Print discovered gateway names
#   ./run.sh status           Show running PIDs annotated with gateway names
#   ./run.sh stop             Stop every gateway
#   ./run.sh stop <name>      Stop only one gateway
#   ./run.sh <name>           Start one gateway in the foreground
#   ./run.sh --help           Print this help
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HERMES_BIN="${HERMES_BIN:-hermes}"
STAGGER_SECONDS="${HERMES_GATEWAY_STAGGER:-2}"

trap 'echo "[run.sh] error on line $LINENO" >&2' ERR

# -----------------------------------------------------------------------------
# Discovery
# -----------------------------------------------------------------------------
# A "gateway" is any immediate subdir of $SCRIPT_DIR that:
#   1. has a `.env` file
#   2. has a `config.yaml` file
#   3. is NOT named with a leading underscore (e.g. `_shared/`)
discover_gateways() {
    local d name
    for d in "$SCRIPT_DIR"/*/; do
        [ -d "$d" ] || continue
        name=$(basename "$d")
        [[ "$name" == _* ]] && continue
        [[ -f "$d/.env" && -f "$d/config.yaml" ]] || continue
        echo "$name"
    done
}

# -----------------------------------------------------------------------------
# Per-gateway runner (subshell-isolated so env vars never leak across gateways)
# -----------------------------------------------------------------------------
inject_and_run() {
    local GW_DIR="$1"
    local GW_PATH="$SCRIPT_DIR/$GW_DIR"

    if [ ! -f "$GW_PATH/.env" ] || [ ! -f "$GW_PATH/config.yaml" ]; then
        echo "[$GW_DIR] ERROR: not a gateway (missing .env or config.yaml)" >&2
        return 1
    fi

    (
        export HERMES_HOME="$GW_PATH"
        export HERMES_EPHEMERAL_SYSTEM_PROMPT=""

        set -a
        # shellcheck disable=SC1091
        source "$GW_PATH/.env"
        set +a

        if [ -z "${HERMES_TELEGRAM_BOT_TOKEN:-}" ]; then
            echo "[$GW_DIR] ERROR: HERMES_TELEGRAM_BOT_TOKEN not set in $GW_PATH/.env" >&2
            exit 1
        fi

        local tlen=${#HERMES_TELEGRAM_BOT_TOKEN}
        echo "[$GW_DIR] token length: $tlen"
        if (( tlen < 45 || tlen > 46 )); then
            echo "[$GW_DIR] WARN: token length $tlen, expected 45-46. Possible \\r from Windows line endings or stray quotes." >&2
        fi

        python3 "$SCRIPT_DIR/inject_config.py"

        echo "[$GW_DIR] starting Hermes Gateway"
        echo "[$GW_DIR] sessions: $HERMES_HOME/sessions"

        cd "$GW_PATH"
        exec "$HERMES_BIN" gateway run
    )
}

# -----------------------------------------------------------------------------
# Status — annotate each Hermes PID with the gateway it serves
# -----------------------------------------------------------------------------
print_status() {
    if ! pgrep -f "hermes gateway run" >/dev/null 2>&1; then
        echo "no Hermes gateways running"
        return 0
    fi
    echo "Hermes gateways RUNNING:"
    local pid home name
    while read -r pid; do
        name="?"
        if [ -r "/proc/$pid/environ" ]; then
            home=$(tr '\0' '\n' < "/proc/$pid/environ" 2>/dev/null | grep '^HERMES_HOME=' | head -1 | cut -d= -f2-)
            [ -n "$home" ] && name=$(basename "$home")
        fi
        echo "  pid=$pid  gateway=$name"
    done < <(pgrep -f "hermes gateway run")
}

# -----------------------------------------------------------------------------
# Stop — all or by name
# -----------------------------------------------------------------------------
stop_one() {
    local name="$1"
    local target="$SCRIPT_DIR/$name"
    local stopped=0
    local pid home
    while read -r pid; do
        [ -r "/proc/$pid/environ" ] || continue
        home=$(tr '\0' '\n' < "/proc/$pid/environ" 2>/dev/null | grep '^HERMES_HOME=' | head -1 | cut -d= -f2-)
        if [ "$home" = "$target" ]; then
            kill "$pid" 2>/dev/null && stopped=1
        fi
    done < <(pgrep -f "hermes gateway run")
    if [ "$stopped" = 1 ]; then
        echo "[stop] killed $name"
    else
        echo "[stop] no running process for $name" >&2
        return 1
    fi
}

stop_all() {
    echo "stopping all Hermes gateways"
    pkill -f "hermes gateway run" 2>/dev/null || true
    find "$SCRIPT_DIR" -maxdepth 2 -name 'gateway.pid' -delete 2>/dev/null || true
    echo "done"
}

# -----------------------------------------------------------------------------
# Start all (with clean Ctrl+C propagation)
# -----------------------------------------------------------------------------
start_all() {
    local gateways
    mapfile -t gateways < <(discover_gateways)
    if [ ${#gateways[@]} -eq 0 ]; then
        echo "no gateways discovered under $SCRIPT_DIR" >&2
        echo "(a gateway is any subdir with both .env and config.yaml; underscore-prefixed dirs are skipped)" >&2
        return 1
    fi

    # Forward SIGINT/SIGTERM to the whole process group so Ctrl+C kills children.
    trap 'kill 0' INT TERM

    local first=true gw
    for gw in "${gateways[@]}"; do
        [ "$first" = true ] || sleep "$STAGGER_SECONDS"
        first=false
        inject_and_run "$gw" &
    done

    echo
    echo "=========================================="
    echo "Hermes Multi-Gateway running (${#gateways[@]} gateway(s))"
    echo "Press Ctrl+C to stop all"
    echo "=========================================="
    wait
}

# -----------------------------------------------------------------------------
# Help
# -----------------------------------------------------------------------------
usage() {
    sed -n '2,21p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'
}

# -----------------------------------------------------------------------------
# Dispatch
# -----------------------------------------------------------------------------
CMD="${1:-all}"
case "$CMD" in
    -h|--help|help)
        usage
        ;;
    all|both|"")
        start_all
        ;;
    list)
        discover_gateways
        ;;
    status)
        print_status
        ;;
    stop)
        if [ "${2:-}" = "" ]; then
            stop_all
        else
            stop_one "$2"
        fi
        ;;
    *)
        # Treat as a gateway name, e.g. `./run.sh work`.
        inject_and_run "$CMD"
        ;;
esac
